{
  "openapi": "3.0.3",
  "paths": {
    "/admin/realms": {
      "get": {
        "operationId": "getRealms",
        "summary": "Get realms",
        "description": "List all realms visible to the current user.",
        "parameters": [
          {
            "name": "briefRepresentation",
            "in": "query",
            "required": false,
            "description": "Only return basic information.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "parameters": [
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "type": "object" } }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/admin/realms/{realm}/broken": {
      "get": {
        "parameters": "not-a-list",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/admin/realms/{realm}": {
      "put": {
        "operationId": "updateRealm",
        "parameters": [
          {
            "name": "realm",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RealmRepresentation" }
            }
          }
        },
        "responses": { "204": { "description": "No Content" } }
      }
    }
  },
  "components": {
    "schemas": {
      "RealmRepresentation": {
        "type": "object",
        "properties": {
          "accessTokenLifespan": { "type": "integer" },
          "self": { "$ref": "#/components/schemas/RealmRepresentation" }
        }
      }
    }
  }
}
